<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.ComboBox?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.Separator?>
<?import javafx.scene.control.TableColumn?>
<?import javafx.scene.control.TableView?>
<?import javafx.scene.layout.BorderPane?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.Region?>
<?import javafx.scene.layout.VBox?>

<BorderPane xmlns="http://javafx.com/javafx/21"
            xmlns:fx="http://javafx.com/fxml/1"
            fx:controller="com.example.java_main_proj.ResultsController"
            prefWidth="900" prefHeight="650">

    <top>
        <VBox spacing="10" style="-fx-background-color: #9C27B0; -fx-padding: 15;">
            <Label text="הצגת תוצאות שיבוץ"
                   style="-fx-font-size: 20px; -fx-font-weight: bold; -fx-text-fill: white;"/>
        </VBox>
    </top>

    <center>
        <VBox spacing="15">
            <padding>
                <Insets top="20" right="20" bottom="20" left="20"/>
            </padding>

            <HBox spacing="15" alignment="CENTER">
                <Label text="סינון לפי:" style="-fx-font-size: 14px; -fx-font-weight: bold;"/>

                <Label text="שנה:"/>
                <ComboBox fx:id="yearFilterCombo" prefWidth="150" promptText="כל השנים"/>

                <Label text="סמסטר:"/>
                <ComboBox fx:id="semesterFilterCombo" prefWidth="150" promptText="כל הסמסטרים"/>

                <Button text="סנן" onAction="#applyFilter"
                        style="-fx-background-color: #2196F3; -fx-text-fill: white;"/>
                <Button text="נקה סינון" onAction="#clearFilter"
                        style="-fx-background-color: #757575; -fx-text-fill: white;"/>
            </HBox>

            <Separator/>

            <HBox spacing="30" alignment="CENTER">
                <VBox alignment="CENTER" spacing="5" style="-fx-background-color: #E3F2FD; -fx-padding: 15; -fx-background-radius: 5;">
                    <Label text="סה״כ סטודנטים" style="-fx-font-size: 12px;"/>
                    <Label fx:id="totalStudentsLabel" text="0"
                           style="-fx-font-size: 24px; -fx-font-weight: bold; -fx-text-fill: #1976D2;"/>
                </VBox>

                <VBox alignment="CENTER" spacing="5" style="-fx-background-color: #E8F5E9; -fx-padding: 15; -fx-background-radius: 5;">
                    <Label text="הצלחה מלאה" style="-fx-font-size: 12px;"/>
                    <Label fx:id="successLabel" text="0"
                           style="-fx-font-size: 24px; -fx-font-weight: bold; -fx-text-fill: #388E3C;"/>
                </VBox>

                <VBox alignment="CENTER" spacing="5" style="-fx-background-color: #FFF3E0; -fx-padding: 15; -fx-background-radius: 5;">
                    <Label text="שיבוץ חלקי" style="-fx-font-size: 12px;"/>
                    <Label fx:id="partialLabel" text="0"
                           style="-fx-font-size: 24px; -fx-font-weight: bold; -fx-text-fill: #F57C00;"/>
                </VBox>
            </HBox>

            <Separator/>

            <Label text="פירוט תוצאות:" style="-fx-font-size: 16px; -fx-font-weight: bold;"/>

            <TableView fx:id="resultsTable" VBox.vgrow="ALWAYS">
                <columns>
                    <TableColumn fx:id="studentIdCol" text="ת.ז" prefWidth="100"/>
                    <TableColumn fx:id="studentNameCol" text="שם הסטודנט" prefWidth="150"/>
                    <TableColumn fx:id="yearCol" text="שנה" prefWidth="80"/>
                    <TableColumn fx:id="requestedCol" text="קורסים מבוקשים" prefWidth="120"/>
                    <TableColumn fx:id="enrolledCol" text="קורסים שובצו" prefWidth="120"/>
                    <TableColumn fx:id="statusCol" text="סטטוס" prefWidth="100"/>
                    <TableColumn fx:id="coursesListCol" text="רשימת קורסים" prefWidth="200"/>
                </columns>
            </TableView>
        </VBox>
    </center>

    <bottom>
        <HBox alignment="CENTER_LEFT" spacing="10" style="-fx-background-color: #f0f0f0;">
            <padding>
                <Insets top="10" right="10" bottom="10" left="10"/>
            </padding>
            <Label fx:id="statusLabel" text="מוכן"/>
            <Region HBox.hgrow="ALWAYS"/>
            <Button text="סגור" onAction="#closeWindow"
                    style="-fx-background-color: #757575; -fx-text-fill: white;"/>
        </HBox>
    </bottom>
</BorderPane>
