<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.TableColumn?>
<?import javafx.scene.control.TableView?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.Region?>
<?import javafx.scene.layout.VBox?>

<VBox xmlns="http://javafx.com/javafx/17" xmlns:fx="http://javafx.com/fxml/1"
      fx:controller="com.example.java_main_proj.StudentController"
      spacing="10" style="-fx-background-color: #f4f4f4;">

    <padding>
        <Insets top="15" right="15" bottom="15" left="15"/>
    </padding>

    <HBox spacing="10" alignment="CENTER_LEFT">
        <TextField fx:id="searchField" promptText="ז.ת וא םש יפל שופיח" prefWidth="300"/>
        <Button text="שפח" onAction="#searchStudent" style="-fx-background-color: #4CAF50; -fx-text-fill: white;"/>
        <Region HBox.hgrow="ALWAYS"/>
        <Button text="טנדוטס ףסוה" onAction="#addStudent" style="-fx-background-color: #2196F3; -fx-text-fill: white;"/>
        <Button text="ךורע" onAction="#editStudent" style="-fx-background-color: #FF9800; -fx-text-fill: white;"/>
        <Button text="קחמ" onAction="#deleteStudent" style="-fx-background-color: #F44336; -fx-text-fill: white;"/>
        <Button text="ןנער" onAction="#refreshTable" style="-fx-background-color: #9E9E9E; -fx-text-fill: white;"/>
    </HBox>

    <TableView fx:id="studentsTable" VBox.vgrow="ALWAYS">
        <columns>
            <TableColumn fx:id="idColumn" text="ההזמ" prefWidth="60"/>
            <TableColumn fx:id="nameColumn" text="אלמ םש" prefWidth="150"/>
            <TableColumn fx:id="idNumberColumn" text="ז.ת" prefWidth="100"/>
            <TableColumn fx:id="yearColumn" text="הנש" prefWidth="60"/>
            <TableColumn fx:id="trackColumn" text="לולסמ" prefWidth="120"/>
            <TableColumn fx:id="priorityColumn" text="תופידע" prefWidth="70"/>
            <TableColumn fx:id="seniorityColumn" text="קתו" prefWidth="60"/>
            <TableColumn fx:id="gpaColumn" text="עצוממ" prefWidth="70"/>
        </columns>
    </TableView>

    <HBox spacing="10" alignment="CENTER_LEFT">
        <Label fx:id="statusLabel" text="ןכומ"/>
        <Region HBox.hgrow="ALWAYS"/>
        <Button text="רוגס" onAction="#closeWindow"/>
    </HBox>
</VBox>
