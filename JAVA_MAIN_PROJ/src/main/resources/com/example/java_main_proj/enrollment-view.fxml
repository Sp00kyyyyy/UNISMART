<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.ComboBox?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.ProgressBar?>
<?import javafx.scene.control.TextArea?>
<?import javafx.scene.layout.BorderPane?>
<?import javafx.scene.layout.GridPane?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.Region?>
<?import javafx.scene.layout.VBox?>

<BorderPane xmlns="http://javafx.com/javafx/21"
            xmlns:fx="http://javafx.com/fxml/1"
            fx:controller="com.example.java_main_proj.EnrollmentController"
            prefWidth="800" prefHeight="600">

    <top>
        <VBox spacing="10" style="-fx-background-color: #FF9800; -fx-padding: 15;">
            <Label text="ידירביה םתירוגלא - םיטנדוטס ץוביש עוציב"
                   style="-fx-font-size: 20px; -fx-font-weight: bold; -fx-text-fill: white;"/>
        </VBox>
    </top>

    <center>
        <VBox spacing="20" alignment="CENTER">
            <padding>
                <Insets top="30" right="30" bottom="30" left="30"/>
            </padding>

            <Label text="ץוביש תורדגה"
                   style="-fx-font-size: 18px; -fx-font-weight: bold;"/>

            <GridPane hgap="15" vgap="15" alignment="CENTER">
                <Label text=":םידומיל תנש" GridPane.columnIndex="1" GridPane.rowIndex="0"
                       style="-fx-font-size: 14px;"/>
                <ComboBox fx:id="yearComboBox" GridPane.columnIndex="0" GridPane.rowIndex="0"
                          prefWidth="200" promptText="הנש רחב"/>

                <Label text=":רטסמס" GridPane.columnIndex="1" GridPane.rowIndex="1"
                       style="-fx-font-size: 14px;"/>
                <ComboBox fx:id="semesterComboBox" GridPane.columnIndex="0" GridPane.rowIndex="1"
                          prefWidth="200" promptText="רטסמס רחב"/>
            </GridPane>

            <VBox spacing="10" alignment="CENTER">
                <Label text=":תומדקתה" style="-fx-font-size: 14px;"/>
                <ProgressBar fx:id="progressBar" prefWidth="400" progress="0"/>
                <Label fx:id="progressLabel" text="0%" style="-fx-font-size: 12px;"/>
            </VBox>

            <TextArea fx:id="logArea" prefHeight="250" editable="false"
                      promptText="...ןאכ עיפוי תולועפ גול"
                      style="-fx-font-family: 'Consolas'; -fx-font-size: 12px;"/>

            <HBox spacing="15" alignment="CENTER">
                <Button text="ץוביש לחתה" onAction="#startEnrollment"
                        prefWidth="150" prefHeight="40"
                        style="-fx-background-color: #4CAF50; -fx-text-fill: white; -fx-font-size: 14px; -fx-font-weight: bold;"/>
                <Button text="רוצע" onAction="#stopEnrollment"
                        prefWidth="150" prefHeight="40"
                        style="-fx-background-color: #F44336; -fx-text-fill: white; -fx-font-size: 14px; -fx-font-weight: bold;"/>
                <Button text="הקנ" onAction="#clearLog"
                        prefWidth="150" prefHeight="40"
                        style="-fx-background-color: #757575; -fx-text-fill: white; -fx-font-size: 14px;"/>
            </HBox>
        </VBox>
    </center>

    <bottom>
        <HBox alignment="CENTER_LEFT" spacing="10" style="-fx-background-color: #f0f0f0;">
            <padding>
                <Insets top="10" right="10" bottom="10" left="10"/>
            </padding>
            <Label fx:id="statusLabel" text="ץובישל ןכומ"/>
            <Region HBox.hgrow="ALWAYS"/>
            <Button text="רוגס" onAction="#closeWindow"
                    style="-fx-background-color: #757575; -fx-text-fill: white;"/>
        </HBox>
    </bottom>
</BorderPane>
