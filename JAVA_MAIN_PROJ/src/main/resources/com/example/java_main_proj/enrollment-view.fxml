<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.ComboBox?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.ProgressBar?>
<?import javafx.scene.control.TextArea?>
<?import javafx.scene.layout.BorderPane?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.Region?>
<?import javafx.scene.layout.VBox?>

<BorderPane xmlns="http://javafx.com/javafx/21"
            xmlns:fx="http://javafx.com/fxml/1"
            fx:controller="com.example.java_main_proj.EnrollmentController"
            prefWidth="800" prefHeight="600">

    <top>
        <VBox spacing="10" style="-fx-background-color: #2E7D32; -fx-padding: 15;">
            <Label text="ביצוע שיבוץ קורסים"
                   style="-fx-font-size: 20px; -fx-font-weight: bold; -fx-text-fill: white;"/>
            <Label text="אלגוריתם היברידי: Greedy + Local Improvement"
                   style="-fx-font-size: 13px; -fx-text-fill: white;"/>
        </VBox>
    </top>

    <center>
        <VBox spacing="15">
            <padding>
                <Insets top="20" right="20" bottom="20" left="20"/>
            </padding>

            <HBox spacing="15" alignment="CENTER_LEFT">
                <Label text="שנת לימודים:" style="-fx-font-weight: bold;"/>
                <ComboBox fx:id="yearComboBox" prefWidth="160"/>
                <Label text="סמסטר:" style="-fx-font-weight: bold;"/>
                <ComboBox fx:id="semesterComboBox" prefWidth="160"/>
            </HBox>

            <VBox spacing="8">
                <Label text="התקדמות:" style="-fx-font-weight: bold;"/>
                <ProgressBar fx:id="progressBar" prefWidth="500" progress="0"/>
                <Label fx:id="progressLabel" text="0%"/>
            </VBox>

            <VBox spacing="8" VBox.vgrow="ALWAYS">
                <Label text="יומן הרצה:" style="-fx-font-weight: bold;"/>
                <TextArea fx:id="logArea" editable="false" wrapText="true" VBox.vgrow="ALWAYS"/>
            </VBox>

            <HBox spacing="10" alignment="CENTER">
                <Button text="התחל שיבוץ" onAction="#startEnrollment"
                        style="-fx-background-color: #4CAF50; -fx-text-fill: white;"/>
                <Button text="נקה" onAction="#clearLog"
                        style="-fx-background-color: #9E9E9E; -fx-text-fill: white;"/>
            </HBox>
        </VBox>
    </center>

    <bottom>
        <HBox alignment="CENTER_LEFT" spacing="10" style="-fx-background-color: #f0f0f0;">
            <padding>
                <Insets top="10" right="10" bottom="10" left="10"/>
            </padding>
            <Label fx:id="statusLabel" text="מוכן"/>
            <Region HBox.hgrow="ALWAYS"/>
            <Button text="סגור" onAction="#closeWindow"
                    style="-fx-background-color: #757575; -fx-text-fill: white;"/>
        </HBox>
    </bottom>
</BorderPane>
